# ============================================================
# EduSpark Web — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# Add these as Environment Variables in your Vercel project.
# ============================================================

# Clerk Authentication (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/reels
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/reels

# Supabase (https://app.supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# API Backend URL (your deployed FastAPI backend)
# Leave blank or set to your Railway/Render backend URL for production
NEXT_PUBLIC_API_URL=https://your-api.railway.app/api/v1

# Cloudinary (optional, for image uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
